{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ffeel",
  "version": "0.2.0",
  "identifier": "com.ffeel.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "ffeel - 局域网文件共享",
        "width": 960,
        "height": 680,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "transparent": true,
        "titleBarStyle": "Transparent"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://github.com/USER/ffeel/releases/latest/download/update-{{target}}-{{arch}}-{{current_version}}.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ1OTQ5RjE4QTlFNTNDRUMKUldUc1BPV3BHSitVUlZDTmxub2ZEYW9INUhFMmhyTitKNmZlTG0rWHpkTjBpOWxvKzRaS0luQnEK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedInstaller"
      },
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
